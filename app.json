{
  "expo": {
    "name": "lumen",
    "slug": "lumen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.tjmady.lumen",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      [
        "react-native-health",
        {
          "isClinicalDataEnabled": false,
          "healthSharePermission": "Lumen reads sleep, heart rate, HRV and step data to correlate with your screen time.",
          "healthUpdatePermission": "Lumen does not write health data."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3cb5ce7d-8182-4db0-bfb4-80cddd020561"
      }
    },
    "owner": "tjtj-cpu-expo"
  }
}
